# ─── Required ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── AI (optional — leave as-is to run in deterministic fallback mode) ─────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Optional overrides ────────────────────────────────────────────────────────
# CORS_ORIGIN=http://localhost:3000    # Default: * (allow all origins)
# MAX_FILE_SIZE_MB=50                  # Default: 50 MB
# LOG_LEVEL=info                       # Default: info (debug|info|warn|error)
